@using FuriousRhino.Web.Sites.Main.Components
@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="fr-site-wrapper">

    <!-- NAV -->
    <nav class="fr-nav" id="fr-nav" role="navigation" aria-label="Main navigation">
        <a href="/" class="nav-brand" @onclick="CloseMenu">
            <FuriousRhinoLogo Size="36" />
            <span class="nav-wordmark">Furious Rhino</span>
        </a>

        <ul class="nav-links" id="fr-nav-links" role="list">
            <li><a href="/#products" @onclick="CloseMenu">Games</a></li>
            <li><a href="/#about" @onclick="CloseMenu">About</a></li>
            <li><a href="/ideas" @onclick="CloseMenu">Ideas</a></li>
            <li><a href="mailto:support@furiousrhino.com">Contact</a></li>
            <li>
                <a href="/#kickstarter" class="nav-cta" @onclick="CloseMenu">
                    Kickstarter
                </a>
            </li>
        </ul>

        <div class="nav-right">
            <button class="hamburger"
                    id="fr-hamburger"
                    @onclick="ToggleMenu"
                    aria-label="Open navigation menu"
                    aria-expanded="@_menuOpen.ToString().ToLower()">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <main>
        @Body
    </main>

    <!-- FOOTER -->
    <footer class="fr-footer" role="contentinfo">
        <div class="footer-brand">
            <FuriousRhinoLogo Size="28" CircleVariant="true" />
            <span>&copy; @DateTime.Now.Year Furious Rhino LLC · Phoenix, AZ</span>
        </div>
        <nav class="footer-links" aria-label="Footer navigation">
            <a href="/#products">Games</a>
            <a href="/#about">About</a>
            <a href="/ideas">Ideas</a>
            <a href="https://resist.bot" target="_blank" rel="noopener">Resistbot</a>
            <a href="mailto:support@furiousrhino.com">Contact</a>
        </nav>
        <p class="footer-legal">Made with questionable judgment and puppies.</p>
    </footer>

</div>

@code {
    private bool _isDark = true;
    private bool _menuOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Read whichever theme JS already applied so the icon matches
            var theme = await JS.InvokeAsync<string>("FuriousRhino.Theme.getCurrent");
            _isDark = theme != "light";
            StateHasChanged();

            // Hook up scroll highlight and reveal for this route
            await JS.InvokeVoidAsync("FuriousRhino.NavHighlight.init");
            await JS.InvokeVoidAsync("FuriousRhino.Reveal.init");
        }
    }

    private async Task ToggleTheme()
    {
        var next = await JS.InvokeAsync<string>("FuriousRhino.Theme.toggle");
        _isDark = next != "light";
    }

    private async Task ToggleMenu()
    {
        _menuOpen = !_menuOpen;
        await JS.InvokeVoidAsync("FuriousRhino.Nav.toggleMenu");
    }

    private async Task CloseMenu()
    {
        if (_menuOpen)
        {
            _menuOpen = false;
            await JS.InvokeVoidAsync("FuriousRhino.Nav.closeMenu");
        }
    }
}
