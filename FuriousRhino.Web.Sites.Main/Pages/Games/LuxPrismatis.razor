@page "/games/lux-prismatis"
@layout MainLayout
@using FuriousRhino.Web.Sites.Main.Components
@using FuriousRhino.Web.Sites.Main.Models
@inject IJSRuntime JS

<PageTitle>Lux Prismatis — Furious Rhino</PageTitle>

<GamePageHero Title="Lux Prismatis"
              Tagline="A geometric light-based puzzle game that I enjoy so maybe you will, too."
              LogoPath="/content/luxlogolarge.png"
              TagLabel="Mobile · iOS & Android"
              TagCssClass="tag-mobile"
              AccentColor="#4da6ff">
    <span class="game-status-badge status-in-progress">In Development</span>
</GamePageHero>

@* ---- OVERVIEW ---- *@
<section class="game-section" id="overview">
    <div class="section-inner">
        <div class="game-overview-grid">
            <div class="game-overview-copy">
                <p class="section-label">Overview</p>
                <h2 class="section-title">Light. Geometry.<br />Flow.</h2>
                <p>
                    Lux Prismatis is a puzzle game built around the movement of light through
                    geometric forms. Each level is a contained system — redirect, split, and
                    combine beams to illuminate every target. Simple to understand, genuinely
                    difficult to master.
                </p>
                <p>
                    Available for iOS and Android, with a Daily Challenge mode that gives
                    everyone the same puzzle each day. Your streak is your business.
                </p>
            </div>
            <div class="game-overview-stats">
                <div class="stat-box">
                    <div class="stat-num">iOS</div>
                    <div class="stat-label">& Android</div>
                </div>
                <div class="stat-box">
                    <div class="stat-num">Daily</div>
                    <div class="stat-label">Challenge mode</div>
                </div>
                <div class="stat-box">
                    <div class="stat-num">∞</div>
                    <div class="stat-label">Levels planned</div>
                </div>
                <div class="stat-box">
                    <div class="stat-num">Free</div>
                    <div class="stat-label">Base game</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ---- SCREENSHOTS ---- *@
<ScreenshotGallery AspectRatio="9/19.5"
                   Label="Screenshots"
                   Title="Work in progress"
                   Screenshots=_screenshots
                   PlaceholderCount="0" />

@* ---- ROADMAP ---- *@
<section class="game-section game-section--alt" id="roadmap">
    <div class="section-inner">
        <div>
            <p class="section-label">Roadmap</p>
            <h2 class="section-title">Where we're at</h2>
        </div>
        <div class="roadmap-track">
            @foreach (var item in _roadmap)
            {
                <div class="roadmap-item roadmap-@item.Status.ToString().ToLower()">
                    <div class="roadmap-marker" aria-hidden="true"></div>
                    <div class="roadmap-content">
                        <div class="roadmap-label">@_statusLabel[item.Status]</div>
                        <h3>@item.Label</h3>
                        <p>@item.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("FuriousRhino.Reveal.init");
    }

    private static readonly Dictionary<RoadmapStatus, string> _statusLabel = new()
    {
        { RoadmapStatus.Done,       "✓ Done"       },
        { RoadmapStatus.InProgress, "⬡ In progress" },
        { RoadmapStatus.Upcoming,   "○ Upcoming"   },
    };

    private static readonly List<RoadmapItem> _roadmap =
    [
        new("Core puzzle engine",
            "The fundamental light-routing mechanics are built and stable. Beams reflect, split, and combine as designed.",
            RoadmapStatus.Done),

        new("Level editor tooling",
            "Internal tools for building and testing levels without redeploying. Lets us iterate on puzzle design quickly.",
            RoadmapStatus.Done),

        new("Daily Challenge API",
            "Server-side level generation for the daily puzzle. Each day produces a unique solvable level seeded by date.",
            RoadmapStatus.InProgress),

        new("Level pack — Base game",
            "The first set of levels for the base game. Targeting 100 puzzles across difficulty tiers.",
            RoadmapStatus.InProgress),

        new("Expansion packs",
            "Additional levels with new objects and complexities for purchase.",
            RoadmapStatus.InProgress),

        new("iOS & Android builds",
            "Platform-specific builds, store listings, and submission to the App Store and Google Play.",
            RoadmapStatus.Upcoming),

        new("Launch",
            "Ship it. Tell people. Hope they like it.",
            RoadmapStatus.Upcoming),

        new("Level expansions",
            "Add more levels to every pack, including the free base game.",
            RoadmapStatus.Upcoming),
    ];

    private static readonly List<ScreenshotItem> _screenshots =
    [
        new("lp1.png", "Main menu"),
        new("lp2.png", "Playing a level"),
        new("lp3.png", "Yay! I win"),
    ];
}
