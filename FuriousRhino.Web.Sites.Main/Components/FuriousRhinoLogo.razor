     viewBox="0 0 802 802"
     width="@Size"
     height="@Size"
     role="img"
     aria-label="@AriaLabel"
     class="fr-logo @CssClass @(CircleVariant ? "fr-logo--circle" : "")"
     style="@_clipStyle">

    <defs>
        @if (CircleVariant)
        {
            <clipPath id="fr-logo-circle-@_uid">
                <circle cx="401" cy="401" r="395" />
            </clipPath>
        }
    </defs>

