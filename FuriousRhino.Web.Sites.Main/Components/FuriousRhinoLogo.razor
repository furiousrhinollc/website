@code {
    /// <summary>Width and height of the rendered SVG in pixels.</summary>
    [Parameter] public int Size { get; set; } = 48;

    /// <summary>Clip the logo to a circle and show a ring border instead of the rounded rect.</summary>
    [Parameter] public bool CircleVariant { get; set; } = false;

    /// <summary>Additional CSS classes applied to the svg element.</summary>
    [Parameter] public string CssClass { get; set; } = string.Empty;

    /// <summary>Accessible label for screen readers.</summary>
    [Parameter] public string AriaLabel { get; set; } = "Furious Rhino logo";

    // Unique ID per instance so multiple logos on one page don't share clipPath ids
    private readonly string _uid = Guid.NewGuid().ToString("N")[..8];

    private string _clipStyle => CircleVariant
        ? "overflow: hidden;"
        : string.Empty;
}
